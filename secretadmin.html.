<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Secret Master Panel</title>
    <style>
        body { background-color: #0f172a; color: white; font-family: sans-serif; text-align: center; padding: 20px; }
        .box { background: #1e293b; padding: 15px; border-radius: 10px; max-width: 450px; margin: 15px auto; border: 2px solid #3b82f6; }
        .btn { background-color: #3b82f6; color: white; border: none; padding: 10px; border-radius: 5px; cursor: pointer; font-weight: bold; width: 45%; margin: 5px; }
        .input-style { padding: 10px; border-radius: 5px; border: none; width: 80%; text-align: center; margin: 10px 0; font-weight: bold; }
        .req-list { text-align: left; background: #0f172a; padding: 10px; border-radius: 5px; font-size: 13px; margin-top: 10px; border-left: 4px solid #f59e0b; }
    </style>
</head>
<body>

    <h1>🔮 SECRET MASTER PANEL</h1>

    <div class="box">
        <h3>🔍 Search Player & Add/Remove Coins</h3>
        <input type="text" id="searchId" class="input-style" placeholder="Enter Player ID (e.g., User-1234)">
        <button onclick="searchPlayer()" class="btn" style="background:#10b981; width:84%;">Check Player Balance</button>
        <p id="searchResult" style="color:#facc15; font-weight:bold; margin-top:10px;"></p>
        
        <input type="number" id="coinAmount" class="input-style" placeholder="Coins Amount to Add/Subtract" style="width:60%;">
        <br>
        <button onclick="updateCoins('add')" class="btn" style="background:#10b981;">➕ Add Coins</button>
        <button onclick="updateCoins('sub')" class="btn" style="background:#ef4444;">➖ Remove Coins</button>
    </div>

    <div class="box">
        <h3>🎯 Game Result Controller</h3>
        <button class="btn" style="background:#ef4444;" onclick="setWinner('andar')">Force Win: ANDAR</button>
        <button class="btn" style="background:#2563eb;" onclick="setWinner('bahar')">Force Win: BAHAR</button>
        <button class="btn" style="background:#64748b; width:92%;" onclick="setWinner('auto')">Reset to Automatic Mode</button>
    </div>

    <div class="box">
        <h3>📥 Live Deposit Requests</h3>
        <div id="requestsLog">No pending requests.</div>
    </div>

    <script type="module">
        import { initializeApp } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-app.js";
        import { getDatabase, ref, onValue, update, set } from "https://www.gstatic.com/firebasejs/10.8.0/firebase-database.js";

        const firebaseConfig = {
            apiKey: "AIzaSyAPRAHTuiVTxDwng6KzCTDZ3-70P2YSN98",
            authDomain: "my-first-app-cad29.firebaseapp.com",
            databaseURL: "https://my-first-app-cad29-default-rtdb.firebaseio.com",
            projectId: "my-first-app-cad29",
            storageBucket: "my-first-app-cad29.appspot.com",
            messagingSenderId: "899016030652",
            appId: "1:899016030652:web:b7d3c0b1294b2db6f453b9"
        };

        const app = initializeApp(firebaseConfig);
        const database = getDatabase(app);
        let activePlayerCoins = 0;
        let activePlayerId = "";

        window.searchPlayer = function() {
            let id = document.getElementById('searchId').value.trim();
            if(!id) return alert("Enter Player ID!");
            onValue(ref(database, 'players/' + id), (snapshot) => {
                if(snapshot.exists()){
                    activePlayerId = id;
                    activePlayerCoins = snapshot.val().coins;
                    document.getElementById('searchResult').innerText = `Player: ${id} | Current Coins: ${activePlayerCoins}`;
                } else {
                    document.getElementById('searchResult').innerText = "Player ID not found!";
                }
            }, { onlyOnce: true });
        }

        window.updateCoins = function(type) {
            if(!activePlayerId) return alert("Search a valid Player ID first!");
            let amt = parseInt(document.getElementById('coinAmount').value);
            if(isNaN(amt) || amt <= 0) return alert("Enter valid coins count!");
            
            let newBalance = type === 'add' ? (activePlayerCoins + amt) : (activePlayerCoins - amt);
            update(ref(database, 'players/' + activePlayerId), { coins: newBalance });
            alert(`Coins updated! New Balance: ${newBalance}`);
            document.getElementById('coinAmount').value = '';
            searchPlayer(); // Refresh log
        }

        window.setWinner = function(side) {
            update(ref(database, 'game'), { forcedWinner: side });
            alert("Target set to: " + side.toUpperCase());
        }

        // Deposit requests fetch karna screen par
        onValue(ref(database, 'depositRequests'), (snapshot) => {
            if(snapshot.exists()) {
                let html = "";
                Object.entries(snapshot.val()).forEach(([key, req]) => {
                    html += `<div class="req-list">
                        <b>ID:</b> ${req.userId} <br>
                        <b>Amount:</b> ${req.amount} Coins <br>
                        <b>UTR/ID:</b> ${req.utr} <br>
                        <button onclick="approveRequest('${key}','${req.userId}', ${req.amount})" style="background:#10b981; border:none; color:white; padding:4px 8px; border-radius:3px; margin-top:5px; font-weight:bold; cursor:pointer;">Approve & Add</button>
                    </div>`;
                });
                document.getElementById('requestsLog').innerHTML = html;
            } else {
                document.getElementById('requestsLog').innerText = "No pending requests.";
            }
        });

        window.approveRequest = function(reqKey, userId, amount) {
            onValue(ref(database, 'players/' + userId), (snapshot) => {
                let currentCoins = snapshot.exists() ? (snapshot.val().coins || 0) : 0;
                update(ref(database, 'players/' + userId), { coins: currentCoins + amount });
                set(ref(database, 'depositRequests/' + reqKey), null); // Request delete karna approve ke baad
                alert("Request approved and coins injected!");
            }, { onlyOnce: true });
        }
    </script>
</body>
</html>
